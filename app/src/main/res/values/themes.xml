<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RadioPlayer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="actionBarPopupTheme">@style/ThemeOverlay.AppCompat.DayNight</item>
        <item name="actionBarTheme">@style/ThemeOverlay.MaterialComponents.Dark.ActionBar</item>
        <item name="spectrumBarColor">@color/spectrum_bar</item>
    </style>

    <style name="Theme.RadioPlayer.FreddieWembley" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#FCD11D</item>
        <item name="colorPrimaryDark">#C9A300</item>
        <item name="colorAccent">#E0218A</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:colorBackground">#000000</item>
        <item name="colorSurface">#1A1A1A</item>
        <item name="colorOnSurface">#FFF5E0</item>
        <item name="android:textColorPrimary">#FFF5E0</item>
        <item name="android:textColorSecondary">#C9B8A0</item>
        <item name="actionBarPopupTheme">@style/ThemeOverlay.RadioPlayer.Wembley.Popup</item>
        <item name="actionBarTheme">@style/ThemeOverlay.RadioPlayer.Wembley.ActionBar</item>
        <item name="spectrumBarColor">#FCD11D</item>
    </style>

    <style name="ThemeOverlay.RadioPlayer.Wembley.ActionBar" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#000000</item>
        <item name="colorControlNormal">#000000</item>
        <item name="colorOnSurface">#000000</item>
        <item name="actionMenuTextColor">#000000</item>
    </style>

    <style name="ThemeOverlay.RadioPlayer.Wembley.Popup" parent="ThemeOverlay.AppCompat.Dark">
        <item name="android:colorBackground">#1A1A1A</item>
        <item name="colorSurface">#1A1A1A</item>
        <item name="android:textColorPrimary">#FFF5E0</item>
        <item name="android:textColorSecondary">#C9B8A0</item>
